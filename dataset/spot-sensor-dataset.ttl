    rdfs:label "FeatureOfInterest" .

# ----------------------- Asset Space ----------------------- #
:AssetSpace a spot:AssetSpace ;
    rdfs:label "Asset Space" ;
    spot:hasXAxis :AssetSpace_AxisX ;
    spot:hasYAxis :AssetSpace_AxisY ;
    spot:hasZAxis :AssetSpace_AxisZ .

:AssetSpace_AxisX a spot:Axis ;
    rdfs:label "Asset Space X Axis" ;
    spot:hasDirection spot:Rear .
:AssetSpace_AxisY a spot:Axis ;
    rdfs:label "Asset Space Y Axis" ;
    spot:hasDirection spot:Left .
:AssetSpace_AxisZ a spot:Axis ;
    rdfs:label "Asset Space Z Axis" ;
    spot:hasDirection spot:Top .

